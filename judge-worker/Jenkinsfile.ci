pipeline {
    agent any

    tools {
        nodejs 'NodeJS-20'
    }

    environment {
        SCANNER_HOME = tool('SonarQubeScanner')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('judge-worker') {
                    sh 'npm install -g pnpm'
                    sh 'pnpm install --frozen-lockfile'
                }
            }
        }

        stage('Prisma Generate') {
            steps {
                dir('judge-worker') {
                    sh 'npx prisma generate'
                }
            }
        }

        stage('Lint') {
            steps {
                dir('judge-worker') {
                    sh 'pnpm run lint || true'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('judge-worker') {
                    sh 'pnpm run test -- --passWithNoTests --coverage'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('judge-worker') {
                    withSonarQubeEnv('SonarQube') {
                        sh "${SCANNER_HOME}/bin/sonar-scanner"
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo '✅ Judge Worker CI pipeline completed successfully!'
        }
        failure {
            echo '❌ Judge Worker CI pipeline failed!'
        }
    }
}
